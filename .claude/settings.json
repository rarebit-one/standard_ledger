{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-worktree.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-push-prepare.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/enforce-signed-commits.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(ALLOW_MULTIPLE_COMMITS=1 gh pr create:*)",
      "Bash(ALLOW_MULTIPLE_COMMITS=1 git push:*)",
      "Bash(SKIP_PRE_PUSH_PREPARE=1 git push:*)"
    ]
  }
}
